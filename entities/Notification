{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Recipient email"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "job",
        "payment",
        "review",
        "order",
        "system"
      ],
      "default": "system"
    },
    "link": {
      "type": "string",
      "description": "Page to navigate to"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_email",
    "title",
    "message"
  ]
}