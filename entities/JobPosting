{
  "name": "JobPosting",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string"
    },
    "client_email": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category_id": {
      "type": "string"
    },
    "budget_min": {
      "type": "number"
    },
    "budget_max": {
      "type": "number"
    },
    "location": {
      "type": "string"
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "closed"
      ],
      "default": "open"
    },
    "skills_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "client_id",
    "title",
    "description"
  ]
}